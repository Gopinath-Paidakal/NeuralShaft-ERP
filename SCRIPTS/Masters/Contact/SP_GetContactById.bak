USE [NSHAFTERPDB]
GO
/****** Object:  StoredProcedure [dbo].[SP_GetContactById.sql]    Script Date: 04/06/2026 ******/
IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[SP_GetContactById]') AND type in (N'P', N'PC'))
DROP PROCEDURE [dbo].[SP_GetContactById]
GO

USE [NSHAFTERPDB]
GO
/****** Object:  StoredProcedure [dbo].[SP_GetContactById]    Script Date: 04/06/2026  ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[SP_GetContactById]
(
	@ContactId int
)
----With Encryption
AS

SET NOCOUNT ON;

BEGIN TRY
		
	SELECT [ContactId]
      ,[ContactType]
      ,[ContactName]
      ,[ContactFirmName]
      ,[ContactDesignation]

      ,[ContactNumber]
      ,[CreatedUserId]
      ,[CreatedDate]

	FROM [dbo].[Contact]

		
	Where ContactId = @ContactId

	FOR JSON PATH, ROOT('Contact');

			
END TRY

	BEGIN CATCH

		Declare 
		@ErrMsg varchar(4000),
		@ErrSeverity int,
		@ErrProcedure varchar(100)

		SET @ErrMsg = (Select Error_Message())
		SET @ErrSeverity = (Select Error_Severity())
		SET @ErrProcedure = (Select Error_Procedure())

		SET @ErrMsg = @ErrMsg + ' / ' + @ErrProcedure
		Raiserror(@ErrMsg,@ErrSeverity,1)
		GOTO End_Prog

	END CATCH

End_Prog:


	




