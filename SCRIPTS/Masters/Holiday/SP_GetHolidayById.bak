USE [NSHAFTERPDB]
GO
/****** Object:  StoredProcedure [dbo].[SP_GetHolidayById.sql]    Script Date: 11/05/2026 ******/
IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[SP_GetHolidayById]') AND type in (N'P', N'PC'))
DROP PROCEDURE [dbo].[SP_GetHolidayById]
GO

USE [NSHAFTERPDB]
GO
/****** Object:  StoredProcedure [dbo].[SP_GetHolidayById]    Script Date: 11/05/2026  ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[SP_GetHolidayById]
(
	@HolidayId int
)
----With Encryption
AS

SET NOCOUNT ON;

BEGIN TRY
		

	SELECT 
		h.[HolidayId],
		h.[BranchId],
		h.[HolidayName],
		h.[HolidayDate],
		h.[HoidayYear],
		h.[HolidayStatus],

		h.[CreatedUserId],
		h.[CreatedDate],

		h.[ModifiedUserId],
		h.[ModifiedDate]

		--b.[BranchName]

	FROM [dbo].[Holiday] h
		INNER JOIN [dbo].[Branch] b
		ON h.BranchId = b.BranchId

	WHERE h.HolidayId = @HolidayId

	FOR JSON PATH, ROOT('Holiday');
	
END TRY

	BEGIN CATCH

		Declare 
		@ErrMsg varchar(4000),
		@ErrSeverity int,
		@ErrProcedure varchar(100)

		SET @ErrMsg = (Select Error_Message())
		SET @ErrSeverity = (Select Error_Severity())
		SET @ErrProcedure = (Select Error_Procedure())

		SET @ErrMsg = @ErrMsg + ' / ' + @ErrProcedure
		Raiserror(@ErrMsg,@ErrSeverity,1)
		GOTO End_Prog

	END CATCH

End_Prog:


	




