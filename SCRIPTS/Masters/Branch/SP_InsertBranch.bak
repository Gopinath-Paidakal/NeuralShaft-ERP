USE [NSHAFTERPDB]
GO
/****** Object:  StoredProcedure [dbo].[SP_InsertBranch]    Script Date: 11/05/2026 ******/
IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[SP_InsertBranch]') AND type in (N'P', N'PC'))
DROP PROCEDURE [dbo].[SP_InsertBranch]
GO

USE [NSHAFTERPDB]
GO
/****** Object:  StoredProcedure [dbo].[SP_InsertBranch]    Script Date: 11/05/2026  ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[SP_InsertBranch]
(
	@Branch nvarchar(Max)

)
----With Encryption
AS

SET NOCOUNT ON;

BEGIN TRY
	Declare @BranchId int

	BEGIN TRANSACTION

	INSERT INTO dbo.Branch
    (
        CompanyId,
        BranchHead,
        BranchCode,
        BranchName,
        BranchAddr1,
        BranchAddr2,
        BranchCity,

        BranchPostalCode,
        BranchWebsite,
        BranchPanNo,
        BranchMobile,
        BranchEmail,
    
        BranchOfficeNo,
        BranchVatNo,
        BranchCstNo,
        BranchServiceTax,
        BranchStatus,
    
        BranchChapterNo,
        BranchExempNotification,
        BranchRange,
        BranchDivision,
        BranchBankName,
    
        BranchBankBranch,
        BranchBankAccNo,
        BranchIfscCode,

        CreatedUserId,
        CreatedDate

    )
SELECT
    CompanyId,
    BranchHead,
    BranchCode,
    BranchName,
    BranchAddr1,
    BranchAddr2,

    BranchCity,
    BranchPostalCode,
    BranchWebsite,
    BranchPanNo,
    BranchMobile,
    
    BranchEmail,
    BranchOfficeNo,
    BranchVatNo,
    BranchCstNo,
    BranchServiceTax,
    
    BranchStatus,
    BranchChapterNo,
    BranchExempNotification,
    BranchRange,
    BranchDivision,
    
    BranchBankName,
    BranchBankBranch,
    BranchBankAccNo,
    BranchIfscCode,

    CreatedUserId,
    CreatedDate

    FROM OPENJSON(@Branch, '$.Branch')
    WITH
    (
        CompanyId INT,
        BranchHead NVARCHAR(200),
        BranchCode NVARCHAR(50),
        BranchName NVARCHAR(100),
        BranchAddr1 NVARCHAR(500),
        BranchAddr2 NVARCHAR(500),

        BranchCity NVARCHAR(100),
        BranchPostalCode NVARCHAR(20),
        BranchWebsite NVARCHAR(200),
        BranchPanNo NVARCHAR(50),
        BranchMobile NVARCHAR(50),
        
        BranchEmail NVARCHAR(200),
        BranchOfficeNo NVARCHAR(50),
        BranchVatNo NVARCHAR(50),
        BranchCstNo NVARCHAR(50),
        BranchServiceTax NVARCHAR(50),
        
        BranchStatus BIT,
        BranchChapterNo NVARCHAR(100),
        BranchExempNotification NVARCHAR(500),
        BranchRange NVARCHAR(100),
        BranchDivision NVARCHAR(100),
        
        BranchBankName NVARCHAR(200),
        BranchBankBranch NVARCHAR(200),
        BranchBankAccNo NVARCHAR(100),
        BranchIfscCode NVARCHAR(50),

        CreatedUserId INT,
        CreatedDate date
    );

    set @BranchId = SCOPE_IDENTITY()

    Select @BranchId

	COMMIT TRANSACTION
END TRY

	BEGIN CATCH
		ROLLBACK TRANSACTION
		Declare 
		@ErrMsg varchar(4000),
		@ErrSeverity int,
		@ErrProcedure varchar(100)

		SET @ErrMsg = (Select Error_Message())
		SET @ErrSeverity = (Select Error_Severity())
		SET @ErrProcedure = (Select Error_Procedure())

		SET @ErrMsg = @ErrMsg + ' / ' + @ErrProcedure
		Raiserror(@ErrMsg,@ErrSeverity,1)
		GOTO End_Prog

	END CATCH

End_Prog: