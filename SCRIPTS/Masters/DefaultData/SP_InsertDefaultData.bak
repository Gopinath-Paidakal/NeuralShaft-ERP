--USE [NSHAFTERPDB]
--GO
--/****** Object:  StoredProcedure [dbo].[SP_InsertDefaultData]    Script Date: 20/03/2026  ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[SP_InsertDefaultData]
(
	@DefaultData nvarchar(Max)

)
----With Encryption
AS

SET NOCOUNT ON;

BEGIN TRY

	--Declare @CompId int
	--Declare @BranchId int

	Declare @DefaultDataId int

     --IF ISJSON(@DefaultData) = 0
     --   BEGIN
     --       --THROW 50001, 'Invalid JSON format', 1;
     --       GOTO End_Prog
     --   END

    --- GST and HSN Code added on 01-06-2026

	BEGIN TRANSACTION

	--- ============= Enquiry

	INSERT INTO [dbo].[DefaultData]
           ([FormType]
           ,[DefaultDataType]
           ,[DefaultProductWidth]
           ,[DefaultProductDepth]
           ,[DefaultDataName]

           ,[DefaultDataDesc]
           ,[DefaultDataStatus]
           ,[Price]
           ,[DefaultTotalStops]
           ,[DefaultCapacity]    --10
           
           ,[DefaultWeight]
           ,[DefaultNoStopPrice]
           ,[DouEntType]
           ,[DouEntPrice901st]
           ,[DouEntPrice902nd]
           
           ,[DouEntPrice1801st]
           ,[DouEntPrice1802nd]
           ,[DouEntPrice1803rd]
           ,[DefaultCabinWidth]
           ,[DefaultCabinDepth]  -- 20
           
           ,[DefaultCabinHeight]
           ,[ShaftTypeWidth]
           ,[ShaftTypeDepth]
           ,[ElevatorSpeed]
           ,[DefaultOverheadHeight]
           
           ,[DefaultElevatorPit]
           ,[DefaultMaxFloors]
           ,[DefaultMinWidthSingle]
           ,[DefaultMinDepthSingle]
           ,[DefaultMinWidthDouble]  --30
           
           ,[DefaultMinDepthDouble]
           ,[DefaultMinWidthTriple]
           ,[DefaultMinDepthTriple]
           ,[DefaultDoorHeight]
           ,[DefaultDoorWidth]

           ,[DefaultDoorMinShaftWidth]
           ,[DefaultDataOrderBy]    -- 37 

           ,[DefaultPowerSupply]
           ,[DefaultMachine]
           ,[DefaultDrive]
           ,[DefaultController]
           ,[DefaultOperation]
           ,[DefaultGuideRails]
           ,[DefaultRope]          -- 44

           ,[DefaultSpecialFeatures]
           ,[DoorFormulaMultiply]
           ,[DoorFormulaAdd]
           ,[DoorTechWidth]
           ,[DoorTechDepth]

           ,[GST]
           ,[HSNCode]

           ,[CabinLeftPanel]
           ,[CabinRightPanel]
           ,[CabinFrontPanel]
           ,[CabinRarePanel]
           
           ,[TentativeDuration1]
           ,[TentativeDuration2]
           ,[TentativeDuration3]
           ,[TentativeDuration4]
           ,[TentativeDuration5]

           ,[TentativeDuration6]
           ,[TentativeDuration7]

           ,[CreatedUserId]
           ,[CreatedDate])    
	
	SELECT    
		   FormType, 
           DefaultDataType, 
           DefaultProductWidth, 
           DefaultProductDepth, 
           DefaultDataName, 

           DefaultDataDesc, 
           DefaultDataStatus, 
           Price, 
           DefaultTotalStops, 
           DefaultCapacity,     --10
           
           DefaultWeight,
           DefaultNoStopPrice,
           DouEntType, 
           DouEntPrice901st,
           DouEntPrice902nd, 
           
           DouEntPrice1801st, 
           DouEntPrice1802nd, 
           DouEntPrice1803rd, 
           DefaultCabinWidth, 
           DefaultCabinDepth,   --20
           
           DefaultCabinHeight, 
           ShaftTypeWidth, 
           ShaftTypeDepth, 
           ElevatorSpeed, 
           DefaultOverheadHeight, 
           
           DefaultElevatorPit, 
           DefaultMaxFloors, 
           DefaultMinWidthSingle, 
           DefaultMinDepthSingle, 
           DefaultMinWidthDouble, --30
           
           DefaultMinDepthDouble, 
           DefaultMinWidthTriple, 
           DefaultMinDepthTriple, 
           DefaultDoorHeight,
           DefaultDoorWidth,

           DefaultDoorMinShaftWidth,
           DefaultDataOrderBy,   -- 37    
           
           DefaultPowerSupply,
           DefaultMachine,
           DefaultDrive,
           DefaultController,
           DefaultOperation,
           DefaultGuideRails,
           DefaultRope,         -- 44

           DefaultSpecialFeatures,
           DoorFormulaMultiply,
           DoorFormulaAdd,
           DoorTechWidth,
           DoorTechDepth,

           GST,
           HSNCode,
           CabinLeftPanel,
           CabinRightPanel,
           CabinFrontPanel,
           CabinRarePanel,

           TentativeDuration1,
           TentativeDuration2,
           TentativeDuration3,
           TentativeDuration4,
           TentativeDuration5,

           TentativeDuration6,
           TentativeDuration7,

           CreatedUserId,
		   CreatedDate

	FROM OPENJSON(@DefaultData, '$.DefaultData')
	WITH
	(
		   FormType nvarchar(100),
           DefaultDataType nvarchar(50),
           DefaultProductWidth int,
           DefaultProductDepth int,
           DefaultDataName nvarchar(100),

           DefaultDataDesc nvarchar(500),
           DefaultDataStatus bit,
           Price numeric(10,2),
           DefaultTotalStops int,
           DefaultCapacity int,              --10
           
           DefaultWeight int,
           DefaultNoStopPrice int,
           DouEntType nvarchar(5),
           DouEntPrice901st int,
           DouEntPrice902nd int,
           
           DouEntPrice1801st int,
           DouEntPrice1802nd int,
           DouEntPrice1803rd int,
           DefaultCabinWidth int,
           DefaultCabinDepth int,   --20
           
           DefaultCabinHeight int,
           ShaftTypeWidth int,
           ShaftTypeDepth int,
           ElevatorSpeed numeric(18,2),
           DefaultOverheadHeight int,
           
           DefaultElevatorPit int,
           DefaultMaxFloors int,
           DefaultMinWidthSingle int,
           DefaultMinDepthSingle int,
           DefaultMinWidthDouble int,   --30
           
           DefaultMinDepthDouble int,
           DefaultMinWidthTriple int,
           DefaultMinDepthTriple int,
           DefaultDoorHeight int,
           DefaultDoorWidth int,        -- 35

           DefaultDoorMinShaftWidth int,
           DefaultDataOrderBy smallint,  --37

           DefaultPowerSupply nvarchar(200),
           DefaultMachine nvarchar(200),
           DefaultDrive nvarchar(200),
           DefaultController nvarchar(200),
           DefaultOperation nvarchar(200),
           DefaultGuideRails nvarchar(200),
           DefaultRope nvarchar(200),   -- 44

           DefaultSpecialFeatures nvarchar(500),
           DoorFormulaMultiply numeric(10,2),
           DoorFormulaAdd int,
           DoorTechWidth int,
           DoorTechDepth int,
                   
           ---- Updated on 01-06-2026
           GST numeric(5,2),
           HSNCode nvarchar(50),

           [CabinLeftPanel] nvarchar(100),
           [CabinRightPanel] nvarchar(100),
           [CabinFrontPanel] nvarchar(100),
           [CabinRarePanel] nvarchar(100),

           [TentativeDuration1] smallint,
           [TentativeDuration2] smallint,
           [TentativeDuration3] smallint,
           [TentativeDuration4] smallint,
           [TentativeDuration5] smallint,

           [TentativeDuration6] smallint,
           [TentativeDuration7] smallint,

           CreatedUserId int,         
           CreatedDate nvarchar(20)
           
	)

	
	SET @DefaultDataId =  SCOPE_IDENTITY();
	--================= =================
	
	Select @DefaultDataId
    --FOR JSON PATH, ROOT('InsertDefaultData')
		
	---- ================================================
	COMMIT TRANSACTION
	
END TRY

	BEGIN CATCH
		
        --IF @@TRANCOUNT > 0
        ROLLBACK TRANSACTION;
		
		Declare 
		@ErrMsg varchar(4000),
		@ErrSeverity int,
		@ErrProcedure varchar(100)

		SET @ErrMsg = (Select Error_Message())
		SET @ErrSeverity = (Select Error_Severity())
		SET @ErrProcedure = (Select Error_Procedure())

		SET @ErrMsg = @ErrMsg + ' / ' + @ErrProcedure
		Raiserror(@ErrMsg,@ErrSeverity,1)
		GOTO End_Prog

	END CATCH

End_Prog:


