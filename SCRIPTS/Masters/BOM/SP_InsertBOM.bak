GO

CREATE PROCEDURE [dbo].[SP_InsertBOM]
(
	@BOM nvarchar(Max)

)
----With Encryption
AS

SET NOCOUNT ON;

BEGIN TRY

	--Declare @CompId int
	--Declare @BranchId int

	Declare @BOMId int

     --IF ISJSON(@DefaultData) = 0
     --   BEGIN
     --       --THROW 50001, 'Invalid JSON format', 1;
     --       GOTO End_Prog
     --   END


	BEGIN TRANSACTION

	--- ============= Enquiry

	INSERT INTO [dbo].[BOM]
           ([ParentProdId]
		   ,[ChildProdId]
           ,[ProdQty]
		   ,[ProdType]
		   ,[UOM]

           ,[CreatedUserId]
		   ,[CreatedDate]
           )
	select
			[ParentProdId],
			[ChildProdId],
			[ProdQty],
		    [ProdType],
		    [UOM],
			
			[CreatedUserId],
			[CreatedDate]

	FROM OPENJSON(@BOM, '$.BOM')
	WITH
	(
		   [ParentProdId] int,
		   [ChildProdId] int, 
           [ProdQty] numeric(18,2),
		   [ProdType] nvarchar(20),
	   	   [UOM] nvarchar(20),

           CreatedUserId int,         
           CreatedDate nvarchar(20)
	)

	
	SET @BOMId =  SCOPE_IDENTITY();
	--================= =================
	
	Select @BOMId
	---- ================================================
	COMMIT TRANSACTION
	
END TRY

	BEGIN CATCH
		
        --IF @@TRANCOUNT > 0
        ROLLBACK TRANSACTION;
		
		Declare 
		@ErrMsg varchar(4000),
		@ErrSeverity int,
		@ErrProcedure varchar(100)

		SET @ErrMsg = (Select Error_Message())
		SET @ErrSeverity = (Select Error_Severity())
		SET @ErrProcedure = (Select Error_Procedure())

		SET @ErrMsg = @ErrMsg + ' / ' + @ErrProcedure
		Raiserror(@ErrMsg,@ErrSeverity,1)
		GOTO End_Prog

	END CATCH

End_Prog:


