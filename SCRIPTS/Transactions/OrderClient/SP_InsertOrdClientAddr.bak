USE [NSHAFTERPDB]
GO
/****** Object:  StoredProcedure [dbo].[SP_InsertOrdClientAddr]    Script Date: 02/04/2026 ******/

IF EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[SP_InsertOrdClientAddr]') AND type IN (N'P', N'PC'))
DROP PROCEDURE [dbo].[SP_InsertOrdClientAddr]
GO

SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[SP_InsertOrdClientAddr]
(
    @OrdClientHdrId int,
    @OrdClientAddr NVARCHAR(MAX)
    --@EnqDtlId int 
)
----With Encryption
AS

SET NOCOUNT ON;

BEGIN TRY
    BEGIN TRANSACTION

    Declare @OrdClientAddrId int

    INSERT INTO [dbo].[OrdClientAddr]
    (
        OrdClientHdrId,
        OrdClientAddr1,
        OrdClientAddr2,
        OrdClientPostalCode,
        OrdClientState,

        OrdClientCity,
        OrdClientPhNo,
        OrdClientCompanyMailId,
        OrdClientWebsite,
        OrdClientPan,

        OrdClientGstNo,
        OrdClientAdhaarNo,
        OrdClientAddrType,
        OrdClientPriContPerson,
        OrdClientPriMailId,

        OrdClientPriMobileNo,
        OrdClientSecContPerson,
        OrdClientSecMailId,
        OrdClientSecMobileNo,
        OrdClientLatitude,

        OrdClientLongitude,
        OrdClientTravelDistance,
        OrdStatus
    )
    SELECT
        @OrdClientHdrId,
        OrdClientAddr1,
        OrdClientAddr2,
        OrdClientPostalCode,
        OrdClientState,

        OrdClientCity,
        OrdClientPhNo,
        OrdClientCompanyMailId,
        OrdClientWebsite,
        OrdClientPan,

        OrdClientGstNo,
        OrdClientAdhaarNo,
        OrdClientAddrType,
        OrdClientPriContPerson,
        OrdClientPriMailId,

        OrdClientPriMobileNo,
        OrdClientSecContPerson,
        OrdClientSecMailId,
        OrdClientSecMobileNo,
        OrdClientLatitude,

        OrdClientLongitude,
        OrdClientTravelDistance,
        OrdStatus

    FROM OPENJSON(@OrdClientAddr, '$.OrdClientAddr')
    WITH
    (
        --OrdClientHdrId INT,
        OrdClientAddr1 NVARCHAR(100),
        OrdClientAddr2 NVARCHAR(100),
        OrdClientPostalCode NVARCHAR(100),
        OrdClientState NVARCHAR(100),

        OrdClientCity NVARCHAR(100),
        OrdClientPhNo NVARCHAR(100),
        OrdClientCompanyMailId NVARCHAR(100),
        OrdClientWebsite NVARCHAR(100),
        OrdClientPan NVARCHAR(100),

        OrdClientGstNo NVARCHAR(100),
        OrdClientAdhaarNo NVARCHAR(100),
        OrdClientAddrType NVARCHAR(100),
        OrdClientPriContPerson NVARCHAR(100),
        OrdClientPriMailId NVARCHAR(100),

        OrdClientPriMobileNo NVARCHAR(100),
        OrdClientSecContPerson NVARCHAR(100),
        OrdClientSecMailId NVARCHAR(100),
        OrdClientSecMobileNo NVARCHAR(100),
        OrdClientLatitude NVARCHAR(100),

        OrdClientLongitude NVARCHAR(100),
        OrdClientTravelDistance NVARCHAR(100),
        OrdStatus NVARCHAR(10)
    );

    set @OrdClientAddrId  = SCOPE_IDENTITY()

    SELECT @OrdClientHdrId;

    COMMIT TRANSACTION

END TRY

BEGIN CATCH
    ROLLBACK TRANSACTION

    DECLARE 
        @ErrMsg VARCHAR(4000),
        @ErrSeverity INT,
        @ErrProcedure VARCHAR(100)

    SET @ErrMsg = ERROR_MESSAGE()
    SET @ErrSeverity = ERROR_SEVERITY()
    SET @ErrProcedure = ERROR_PROCEDURE()

    SET @ErrMsg = @ErrMsg + ' / ' + ISNULL(@ErrProcedure, '')

    RAISERROR(@ErrMsg, @ErrSeverity, 1)
    GOTO End_Prog

END CATCH

End_Prog:


 -------------------------------------------------
    -------- Update EnqDql Customer Status
    -------------------------------------------------
    --if (@EnqDtlId > 0)
    --BEGIN
    --    Update EnqDtl set OrdClientHdrId = @OrdClientHdrId, CustomerStatus = 'Created' where EnqDtlId = @EnqDtlId
    --END